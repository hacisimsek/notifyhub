PUBLIC_DOMAIN=example.com
ACME_EMAIL=admin@example.com

POSTGRES_USER=notifyhub
POSTGRES_PASSWORD=replace-with-strong-postgres-password
POSTGRES_DB=notifyhub

RABBITMQ_USERNAME=notifyhub
RABBITMQ_PASSWORD=replace-with-strong-rabbitmq-password

AUTH_JWT_ISSUER=notifyhub-auth
AUTH_JWT_SECRET=replace-with-at-least-64-random-characters
AUTH_JWT_EXPIRATION=PT2H

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-with-strong-grafana-password

KIBANA_BASIC_AUTH_USER=admin
KIBANA_BASIC_AUTH_HASH=replace-with-caddy-hash-password-output

ELASTIC_VERSION=8.19.15
ELASTICSEARCH_JAVA_OPTS=-Xms768m -Xmx768m
LOGSTASH_JAVA_OPTS=-Xms256m -Xmx256m
BACKEND_JAVA_TOOL_OPTIONS=-Xms128m -Xmx384m
KAFKA_HEAP_OPTS=-Xms256m -Xmx512m
PROMETHEUS_RETENTION=7d
POSTGRES_BACKUP_RETENTION_DAYS=7

KAFKA_TOPIC_REMINDER_TRIGGERED=reminder.triggered
KAFKA_NOTIFICATION_GROUP_ID=notification-service
REMINDER_TRIGGER_SCHEDULER_DELAY_MS=5000
RABBITMQ_ENABLED=true
NOTIFICATION_DELIVERY_MAX_ATTEMPTS=3
NOTIFICATION_DELIVERY_RETRY_DELAY_MS=5000
